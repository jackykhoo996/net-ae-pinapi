# Carrier API base URL (GET requests — query params are built by the handler)
# Both actions use the same base URL; action param differs per handler
REQUEST_PIN_API_URL=https://prod.api.puretechglobal.net/api_hub/api_hub
VERIFY_PIN_API_URL=https://prod.api.puretechglobal.net/api_hub/api_hub

# Your Vercel deployment domain — sent as domain_name param to carrier
# Example: net-ae-pinapi.vercel.app  or your custom domain
DOMAIN_NAME=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Voluum postback — {click_id} is substituted at runtime
VOLUUM_POSTBACK_URL=http://citcycle-sative.com/postback?cid={click_id}&payout=2
