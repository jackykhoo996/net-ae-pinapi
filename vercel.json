{
  "version": 2,
  "public": false,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "dashboard/**", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/dashboard", "dest": "/dashboard/index.html" },
    { "src": "/dashboard/(.*)", "dest": "/dashboard/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
