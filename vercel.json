{
  "version": 2,
  "public": false,
  "headers": [
    {
      "source": "/(.*\\.css|.*\\.js|.*\\.png|.*\\.jpg|.*\\.ico|.*\\.woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/dashboard", "status": 308, "headers": { "Location": "/dashboard/" } },
    { "src": "/dashboard/", "dest": "/public/dashboard/index.html" },
    { "src": "/dashboard/(.*)", "dest": "/public/dashboard/$1" },
    { "src": "/v2", "status": 308, "headers": { "Location": "/v2/" } },
    { "src": "/v2/", "dest": "/public/v2/index.html" },
    { "src": "/v2/(.*)", "dest": "/public/v2/$1" },
    { "src": "/v3", "status": 308, "headers": { "Location": "/v3/" } },
    { "src": "/v3/", "dest": "/public/v3/index.html" },
    { "src": "/v3/(.*)", "dest": "/public/v3/$1" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
